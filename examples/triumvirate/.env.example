# Triumvirate (Dockerized, generic example) — environment variables
# Copy to .env and fill in.  docker-compose reads this file at container
# startup and exposes the values to the conductor and its three children.

# --- Required --------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...

# GitLab Personal Access Token — needed by the miner's GitLab MCP server.
# Token needs at minimum `read_api` and `read_repository` scopes.  Get it
# from your GitLab profile → User Settings → Access Tokens.  If you don't
# have GitLab access, remove the `gitlab` block from
# recipes/knowledge-miner.json before running `docker compose up`.
GITLAB_TOKEN=glpat-...
GITLAB_API_URL=https://gitlab.example.com/api/v4

# --- Optional: model override (default is per-recipe) ----------------------
# MODEL=claude-opus-4-6

# --- Notion via syncntn ----------------------------------------------------
# Not part of the generic example — see lynx-conhost-recipes/docker_files
# for the org-specific Triumvirate variant that bakes syncntn in.
